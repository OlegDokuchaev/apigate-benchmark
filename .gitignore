# ---- OS / FS cruft ----
.DS_Store
Thumbs.db
desktop.ini
*~

# ---- Editors / IDEs ----
.idea/
*.iml
.vscode/
*.swp
*.swo
.claude/

# ---- Go ----
# Go build/test artifacts. go.sum IS committed (reproducible builds).
*.exe
*.test
*.prof
*.out
vendor/

# ---- Rust ----
# Cargo.lock IS committed for binary crates — reproducible release builds.
target/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ---- k6 load tests ----
# Per-run summaries; regenerated by load-tests/run.sh each invocation.
load-tests/results/

# ---- Env files ----
# The `.env` / `.env.docker` files in each service ARE committed — they hold
# dev-default values that docker-compose references via `env_file:`. Local
# override files follow the Next.js-style `*.local` convention and stay out.
.env.local
.env.*.local
